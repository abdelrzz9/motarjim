{
  "name": "motarjim",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @motarjim/web",
    "build": "npm run build -w @motarjim/web",
    "preview": "npm run preview -w @motarjim/web",
    "lint": "eslint apps/ --ext .ts,.tsx",
    "format": "prettier --write 'apps/**/*.{ts,tsx,css}'",
    "typecheck": "npm run typecheck -w @motarjim/web"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
